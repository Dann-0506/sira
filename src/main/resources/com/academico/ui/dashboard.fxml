<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.academico.controller.DashboardController">

    <!-- Sidebar -->
    <left>
        <VBox spacing="0"
              prefWidth="220" minWidth="220"
              style="-fx-background-color: -color-bg-subtle;
                     -fx-border-color: -color-border-default;
                     -fx-border-width: 0 1 0 0;">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <!-- Perfil -->
            <VBox spacing="2">
                <padding><Insets bottom="12"/></padding>
                <Label fx:id="labelNombreUsuario"
                       text="Cargando..."
                       styleClass="text-bold"
                       style="-fx-font-size: 14px;"/>
                <Label fx:id="labelRolUsuario"
                       styleClass="text-muted"
                       style="-fx-font-size: 12px;"/>
            </VBox>

            <Separator/>
            <Region prefHeight="8"/>

            <!-- Menú dinámico -->
            <VBox fx:id="menuNavegacion" spacing="2" VBox.vgrow="ALWAYS"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator/>
            <Region prefHeight="8"/>

            <!-- Cerrar sesión -->
            <Button text="Cerrar sesión"
                    maxWidth="Infinity"
                    styleClass="flat, danger"
                    onAction="#handleCerrarSesion"/>
        </VBox>
    </left>

    <!-- Contenido principal -->
    <center>
        <StackPane fx:id="areaPrincipal"
                   style="-fx-background-color: -color-bg-default;
                          -fx-padding: 32;">
            <VBox alignment="CENTER" spacing="8">
                <Label fx:id="labelBienvenida"
                       styleClass="title-3"/>
                <Label text="Selecciona una opción del menú para comenzar."
                       styleClass="text-muted"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>