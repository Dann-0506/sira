<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.academico.controller.RespaldosController">
    
    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f8f9fa;">
        
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox>
                <Label text="Administración de Respaldos" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Crea, descarga y restaura copias de seguridad físicas de la base de datos." style="-fx-text-fill: #6c757d; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Generar Nuevo Respaldo Ahora" onAction="#handleCrearRespaldo" styleClass="success" style="-fx-pref-height: 40; -fx-font-weight: bold; -fx-padding: 0 20;"/>
        </HBox>

        <TableView fx:id="tablaRespaldos" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8;">
            <placeholder>
                <Label text="No se encontraron respaldos en la carpeta local."/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colNombre" text="Nombre del Archivo" prefWidth="300" />
                <TableColumn fx:id="colFecha" text="Fecha de Creación" prefWidth="200" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colTamano" text="Tamaño" prefWidth="120" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAcciones" text="Acciones Críticas" prefWidth="250" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <StackPane fx:id="panelConfirmacion" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.6);">
        <VBox maxWidth="450" maxHeight="-Infinity" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 5); -fx-padding: 30; -fx-border-color: #dc3545; -fx-border-width: 4 0 0 0; -fx-border-radius: 12;">
            
            <Label fx:id="lblTituloConfirmacion" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #dc3545;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true" style="-fx-text-fill: #495057; -fx-font-size: 14px; -fx-line-spacing: 0.3em;"/>
            
            <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 15 0 0 0;">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion" styleClass="flat" style="-fx-pref-height: 40; -fx-font-weight: bold;"/>
                <Button fx:id="btnConfirmarAccion" text="¡ESTOY SEGURO, CONTINUAR!" onAction="#handleEjecutarConfirmacion" style="-fx-pref-height: 40; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true" StackPane.alignment="BOTTOM_CENTER" style="-fx-translate-y: -40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);"/>

    <StackPane fx:id="panelCarga" visible="false" managed="false" style="-fx-background-color: rgba(255,255,255,0.8);">
        <VBox alignment="CENTER" spacing="15">
            <ProgressIndicator prefWidth="50" prefHeight="50" />
            <Label text="Procesando base de datos. Por favor, no cierres el sistema..." style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>
    </StackPane>

</StackPane>