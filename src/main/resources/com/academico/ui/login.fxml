<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.academico.controller.LoginController"
           style="-fx-background-color: #E8EDF2;">

    <VBox spacing="0"
          maxWidth="400"
          maxHeight="400"
          style="-fx-background-color: white;
                 -fx-background-radius: 12;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 20, 0, 0, 4);">
             
        <!-- Encabezado -->
        <VBox alignment="CENTER" spacing="6">
            <padding><Insets top="32" right="32" bottom="24" left="32"/></padding>
            <Label text="Registro Académico"
                   styleClass="title-2"/>
            <Label text="Ingresa tus credenciales para continuar"
                   styleClass="text-muted"/>
        </VBox>

        <Separator/>

        <!-- Formulario -->
        <VBox spacing="16">
            <padding><Insets top="24" right="32" bottom="0" left="32"/></padding>

            <VBox spacing="4">
                <Label text="Correo electrónico" styleClass="text-bold"/>
                <TextField fx:id="campEmail"
                           promptText="usuario@institucion.edu"/>
                <Label fx:id="errorEmail"
                       styleClass="text-danger"
                       visible="false"
                       managed="false"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Contraseña" styleClass="text-bold"/>
                <PasswordField fx:id="campPassword"
                               promptText="••••••••"/>
                <Label fx:id="errorPassword"
                       styleClass="text-danger"
                       visible="false"
                       managed="false"/>
            </VBox>

            <Label fx:id="errorGeneral"
                   styleClass="text-danger"
                   wrapText="true"
                   visible="false"
                   managed="false"/>
        </VBox>

        <VBox>
              <padding><Insets top="24" right="32" bottom="32" left="32"/></padding>
              <Button fx:id="botonLogin"
                     text="Iniciar sesión"
                     maxWidth="Infinity"
                     defaultButton="true"
                     styleClass="accent"
                     onAction="#handleLogin"/>
       </VBox>

    </VBox>

</StackPane>