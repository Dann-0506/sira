<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="25" style="-fx-background-color: -color-bg-default; -fx-padding: 30;" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.academico.controller.MisCursosAlumnoController">

    <VBox spacing="5">
        <Label text="Mi Historial Académico" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #24292f;"/>
        <Label text="Consulta tus cursos actuales y el registro histórico de tus semestres anteriores." 
               style="-fx-text-fill: #57606a; -fx-font-size: 14px;"/>
    </VBox>

    <Label fx:id="labelCargando" text="Cargando cursos..." style="-fx-font-size: 14px; -fx-text-fill: #57606a;"/>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <content>
            <FlowPane fx:id="contenedorTarjetas" hgap="20" vgap="20">
                <padding>
                    <Insets bottom="20" left="5" right="5" top="5" />
                </padding>
                </FlowPane>
        </content>
    </ScrollPane>
</VBox>