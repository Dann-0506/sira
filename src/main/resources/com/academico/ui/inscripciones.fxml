<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.academico.controller.InscripcionesController">
    
    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f8f9fa;">
        
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Gestión de Inscripciones" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            
            <Button text="Importar CSV" onAction="#handleImportarCsv" styleClass="button-outlined" style="-fx-pref-height: 35;">
                <tooltip>
                    <Tooltip text="Formato esperado:&#10;• Matrícula del Alumno&#10;• Clave del Grupo&#10;• Semestre" />
                </tooltip>
            </Button>

            <TextField fx:id="campoBusqueda" promptText="Buscar alumno, matrícula o grupo..." onKeyReleased="#handleBusqueda" prefWidth="300" style="-fx-pref-height: 35;"/>
            <Button text="+ Nueva Inscripción" onAction="#handleNuevo" styleClass="accent" style="-fx-pref-height: 35; -fx-font-weight: bold;"/>
        </HBox>

        <TableView fx:id="tablaInscripciones" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8;">
            <placeholder>
                <Label text="No hay inscripciones registradas en el sistema."/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colMatricula" text="Matrícula" prefWidth="120" />
                <TableColumn fx:id="colAlumno" text="Alumno" prefWidth="250" />
                <TableColumn fx:id="colGrupoClave" text="Grupo" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colMateria" text="Materia" prefWidth="200" />
                <TableColumn fx:id="colSemestre" text="Semestre" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colFecha" text="Fecha Inscripción" prefWidth="120" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="100" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN" />
            </columnResizePolicy>
        </TableView>

        <Pagination fx:id="paginacionInscripciones" maxPageIndicatorCount="5" />
    </VBox>

    <StackPane fx:id="panelFormulario" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="500" maxHeight="-Infinity" spacing="20" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 30;">
            
            <Label text="Inscribir Alumno a Grupo" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            
            <VBox spacing="5">
                <Label text="Seleccionar Alumno *" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbAlumno" maxWidth="Infinity" editable="true" promptText="Buscar por nombre o matrícula..." style="-fx-pref-height: 35;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Seleccionar Grupo *" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbGrupo" maxWidth="Infinity" editable="true" promptText="Buscar por clave o materia..." style="-fx-pref-height: 35;"/>
                <Label text="Nota: Solo se muestran grupos marcados como 'ACTIVOS'." style="-fx-text-fill: #6c757d; -fx-font-size: 11px;"/>
            </VBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Region HBox.hgrow="ALWAYS"/> 
                <Button text="Cancelar" onAction="#handleCancelar" styleClass="flat" style="-fx-pref-height: 35;"/>
                <Button text="Inscribir" onAction="#handleGuardar" styleClass="accent" style="-fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="panelConfirmacion" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 30;">
            <Label fx:id="lblTituloConfirmacion" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true" style="-fx-text-fill: #495057; -fx-font-size: 14px;"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion" styleClass="flat" style="-fx-pref-height: 35;"/>
                <Button fx:id="btnConfirmarAccion" text="Confirmar Baja" onAction="#handleEjecutarConfirmacion" styleClass="danger" style="-fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true" StackPane.alignment="BOTTOM_CENTER" style="-fx-translate-y: -40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);"/>

</StackPane>