<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.academico.controller.MateriasController">
    
    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f8f9fa;">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Catálogo de Materias" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            
            <Button text="Importar CSV" onAction="#handleImportarCsv" styleClass="button-outlined" style="-fx-pref-height: 35;">
                <tooltip>
                    <Tooltip text="Formato esperado:&#10;• CLAVE&#10;• NOMBRE DE LA MATERIA&#10;• TOTAL DE UNIDADES" />
                </tooltip>
            </Button>

            <TextField fx:id="campoBusqueda" promptText="Buscar clave o nombre..." onKeyReleased="#handleBusqueda" prefWidth="250" style="-fx-pref-height: 35;"/>
            <Button text="+ Nueva Materia" onAction="#handleNuevo" styleClass="accent" style="-fx-pref-height: 35; -fx-font-weight: bold;"/>
        </HBox>

        <TableView fx:id="tablaMaterias" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8;">
            <placeholder><Label text="No se encontraron materias registradas."/></placeholder>
            <columns>
                <TableColumn fx:id="colClave" text="Clave" prefWidth="100" />
                <TableColumn fx:id="colNombre" text="Nombre de la Materia" prefWidth="350" />
                <TableColumn fx:id="colTotalUnidades" text="Unidades" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="250" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN" /></columnResizePolicy>
        </TableView>
        <Pagination fx:id="paginacionMaterias" maxPageIndicatorCount="5" />
    </VBox>

    <StackPane fx:id="panelFormulario" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="450" maxHeight="-Infinity" spacing="20" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 30;">
            <Label fx:id="labelTituloFormulario" text="Nueva Materia" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            
            <VBox spacing="5">
                <Label text="Clave *" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoClave" promptText="Ej. MAT-101" style="-fx-pref-height: 35;"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Nombre de la Materia *" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoNombreMateria" promptText="Ej. Matemáticas Discretas" style="-fx-pref-height: 35;"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Total de Unidades *" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoTotalUnidades" promptText="Ej. 5" style="-fx-pref-height: 35;"/>
            </VBox>
            <Label text="Nota: Las unidades no se pueden alterar una vez creada la materia por seguridad académica." style="-fx-text-fill: #6c757d; -fx-font-size: 11px;" wrapText="true"/>
            
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelar" styleClass="flat" style="-fx-pref-height: 35;"/>
                <Button text="Guardar" onAction="#handleGuardar" styleClass="accent" style="-fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="panelUnidades" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="550" maxHeight="500" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 30;">
            <Label fx:id="lblTituloUnidades" text="Unidades de la Materia" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            
            <TableView fx:id="tablaUnidades" VBox.vgrow="ALWAYS">
                <placeholder><Label text="No hay unidades registradas."/></placeholder>
                <columns>
                    <TableColumn fx:id="colUnidadNumero" text="No." prefWidth="60" style="-fx-alignment: CENTER;" />
                    <TableColumn fx:id="colUnidadNombre" text="Nombre Temático de la Unidad" prefWidth="400" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN" /></columnResizePolicy>
            </TableView>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="campoNombreUnidad" promptText="Selecciona una unidad en la tabla para renombrarla..." HBox.hgrow="ALWAYS" style="-fx-pref-height: 35;" disable="true"/>
                <Button fx:id="btnGuardarUnidad" text="Actualizar Nombre" onAction="#handleGuardarNombreUnidad" styleClass="accent" style="-fx-pref-height: 35;" disable="true"/>
            </HBox>

            <HBox alignment="CENTER_RIGHT">
                <Button text="Cerrar Panel" onAction="#handleCerrarUnidades" styleClass="flat" style="-fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="panelConfirmacion" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 30;">
            <Label fx:id="lblTituloConfirmacion" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true" style="-fx-text-fill: #495057; -fx-font-size: 14px;"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion" styleClass="flat" style="-fx-pref-height: 35;"/>
                <Button fx:id="btnConfirmarAccion" text="Confirmar" onAction="#handleEjecutarConfirmacion" style="-fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true" StackPane.alignment="BOTTOM_CENTER" style="-fx-translate-y: -40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);"/>

</StackPane>