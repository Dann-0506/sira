<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.academico.controller.GruposController">
    
    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f8f9fa;">
        
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Catálogo de Grupos Académicos" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            
            <Button text="Importar CSV" onAction="#handleImportarCSV" styleClass="button-outlined" style="-fx-pref-height: 35;">
                <tooltip>
                    <Tooltip text="Formato esperado:&#10;• CLAVE DE LA MATERIA&#10;• NUM DE EMPLEADO&#10;• CLAVE DEL GRUPO&#10;• SEMESTRE" />
                </tooltip>
            </Button>

            <TextField fx:id="campoBusqueda" promptText="Buscar por clave, materia o docente..." onKeyReleased="#handleBusqueda" prefWidth="250" style="-fx-pref-height: 35;"/>
            <Button text="+ Nuevo Grupo" onAction="#handleNuevo" styleClass="accent" style="-fx-pref-height: 35; -fx-font-weight: bold;"/>
        </HBox>

        <TableView fx:id="tablaGrupos" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8;">
            <placeholder>
                <Label text="No se encontraron grupos registrados para este ciclo."/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colClave" text="Clave" prefWidth="120" />
                <TableColumn fx:id="colMateria" text="Materia" prefWidth="250" />
                <TableColumn fx:id="colMaestro" text="Docente" prefWidth="250" />
                <TableColumn fx:id="colSemestre" text="Semestre" prefWidth="120" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="200" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN" />
            </columnResizePolicy>
        </TableView>

        <Pagination fx:id="paginacionGrupos" maxPageIndicatorCount="5" />
    </VBox>

    <StackPane fx:id="panelFormulario" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="450" maxHeight="-Infinity" spacing="20" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 30;">
            
            <Label fx:id="labelTituloFormulario" text="Nuevo Grupo" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            
            <VBox spacing="5">
                <Label text="Materia *" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbMateria" maxWidth="Infinity" editable="true" promptText="Seleccione o busque materia..." style="-fx-pref-height: 35;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Docente *" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbMaestro" maxWidth="Infinity" editable="true" promptText="Seleccione o busque docente..." style="-fx-pref-height: 35;"/>
            </VBox>

            <HBox spacing="10">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Clave del Grupo *" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="campoClave" promptText="Ej. MAT-101-A" style="-fx-pref-height: 35;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Semestre *" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="campoSemestre" promptText="Ej. 2024-1" style="-fx-pref-height: 35;"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Region HBox.hgrow="ALWAYS"/> 
                <Button text="Cancelar" onAction="#handleCancelar" styleClass="flat" style="-fx-pref-height: 35;"/>
                <Button text="Guardar" onAction="#handleGuardar" styleClass="accent" style="-fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="panelConfirmacion" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 30;">
            <Label fx:id="lblTituloConfirmacion" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true" style="-fx-text-fill: #495057; -fx-font-size: 14px;"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion" styleClass="flat" style="-fx-pref-height: 35;"/>
                <Button fx:id="btnConfirmarAccion" text="Confirmar" onAction="#handleEjecutarConfirmacion" style="-fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true" StackPane.alignment="BOTTOM_CENTER" style="-fx-translate-y: -40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);"/>

</StackPane>