<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.academico.controller.AlumnosController">

    <top>
        <HBox alignment="CENTER">
            <VBox spacing="20" maxWidth="1300" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="20" left="20" right="20" top="15"/>
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Catálogo de Alumnos" styleClass="title-2"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Formato CSV esperado:" style="-fx-font-size: 10px; -fx-text-fill: -color-fg-muted;"/>
                        <Label text="MATRÍCULA, NOMBRE, CORREO" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                    </VBox>

                    <Button text="Importar CSV" styleClass="flat" onAction="#handleImportarCsv">
                        <tooltip>
                            <Tooltip text="Suba un archivo .csv (opcional con encabezado). Columnas: Matrícula, Nombre, Correo."/>
                        </tooltip>
                    </Button>
                    <Button text="Nuevo alumno" styleClass="accent" onAction="#handleNuevo"/>
                </HBox>
                
                <HBox alignment="CENTER_LEFT" spacing="30">
                    <TextField fx:id="campoBusqueda"
                            promptText="Buscar por nombre o matrícula..."
                            maxWidth="500" 
                            prefHeight="40"
                            HBox.hgrow="ALWAYS"
                            onKeyReleased="#handleBusqueda"/>

                    <Label fx:id="mensajeGeneral" 
                            wrapText="true" 
                            alignment="CENTER"
                            maxWidth="Infinity"
                            visible="false" 
                            managed="false" 
                            style="-fx-font-size: 14px; -fx-padding: 8 15; -fx-background-radius: 5;"/>
                </HBox>
            </VBox>
        </HBox>
    </top>

    <center>
        <StackPane alignment="TOP_CENTER">
            <padding>
                <Insets bottom="20" left="20" right="20" top="0"/>
            </padding>

            <HBox spacing="20" maxWidth="1300" alignment="TOP_CENTER">

                <VBox HBox.hgrow="ALWAYS" spacing="22">
                    <TableView fx:id="tablaAlumnos" VBox.vgrow="ALWAYS">
                        <placeholder>
                            <Label text="No se encontraron alumnos con los criterios de búsqueda."/>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colMatricula" text="Matrícula" prefWidth="150" reorderable="false"/>
                            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="250" reorderable="false"/>
                            <TableColumn fx:id="colEmail" text="Correo Electrónico" prefWidth="300" reorderable="false"/>
                            <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="180" reorderable="false" style="-fx-alignment: CENTER;"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                        </columnResizePolicy>
                    </TableView>
                    
                    <Pagination fx:id="paginacionAlumnos" maxPageIndicatorCount="5" styleClass="flat"/>
                </VBox>

                <VBox fx:id="panelFormulario"
                      spacing="20"
                      prefWidth="320"
                      minWidth="320"
                      visible="false"
                      managed="false"
                      style="-fx-background-color: -color-bg-subtle;
                             -fx-background-radius: 10;
                             -fx-padding: 20;
                             -fx-border-color: -color-border-muted;
                             -fx-border-radius: 10;">

                    <Label fx:id="labelTituloFormulario"
                           text="Nuevo alumno"
                           styleClass="title-4"/>

                    <Separator/>

                    <VBox spacing="8">
                        <Label text="Matrícula *" styleClass="text-bold"/>
                        <TextField fx:id="campoMatricula" promptText="Ej. 20230001" prefHeight="35"/>
                        <Label fx:id="errorMatricula" styleClass="text-danger" visible="false" managed="false"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="Nombre completo *" styleClass="text-bold"/>
                        <TextField fx:id="campoNombre" promptText="Ej. Juan Pérez García" prefHeight="35"/>
                        <Label fx:id="errorNombre" styleClass="text-danger" visible="false" managed="false"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="Correo electrónico" styleClass="text-bold"/>
                        <TextField fx:id="campoEmail" promptText="Ej. juan@correo.com" prefHeight="35"/>
                        <Label fx:id="errorEmail" styleClass="text-danger" visible="false" managed="false"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>

                    <HBox spacing="10">
                        <Button text="Cancelar"
                                styleClass="flat"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"
                                prefHeight="40"
                                onAction="#handleCancelar"/>
                        <Button fx:id="botonGuardar"
                                text="Guardar"
                                styleClass="accent"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"
                                prefHeight="40"
                                onAction="#handleGuardar"/>
                    </HBox>
                </VBox>

            </HBox>
        </StackPane>
    </center>

</BorderPane>