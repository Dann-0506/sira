<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.academico.controller.AlumnosController">
    
    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f8f9fa;">
        
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Catálogo de Alumnos" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            
            <Button text="Importar CSV" onAction="#handleImportarCsv" styleClass="button-outlined" style="-fx-pref-height: 35;">
                <tooltip>
                    <Tooltip text="Formato esperado:&#10;• MATRÍCULA&#10;• NOMBRE COMPLETO&#10;• CORREO" />
                </tooltip>
            </Button>

            <TextField fx:id="campoBusqueda" promptText="Buscar por nombre o matrícula..." onKeyReleased="#handleBusqueda" prefWidth="250" style="-fx-pref-height: 35;"/>
            <Button text="+ Nuevo Alumno" onAction="#handleNuevo" styleClass="accent" style="-fx-pref-height: 35; -fx-font-weight: bold;"/>
        </HBox>

        <TableView fx:id="tablaAlumnos" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8;">
            <placeholder>
                <Label text="No se encontraron alumnos registrados."/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colMatricula" text="Matrícula" prefWidth="150" />
                <TableColumn fx:id="colNombre" text="Nombre Completo" prefWidth="300" />
                <TableColumn fx:id="colEmail" text="Correo Electrónico" prefWidth="250" />
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="220" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN" />
            </columnResizePolicy>
        </TableView>

        <Pagination fx:id="paginacionAlumnos" maxPageIndicatorCount="5" />
    </VBox>

    <StackPane fx:id="panelFormulario" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="450" maxHeight="-Infinity" spacing="20" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 30;">
            
            <Label fx:id="labelTituloFormulario" text="Nuevo Alumno" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            
            <VBox spacing="5">
                <Label text="Matrícula *" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoMatricula" promptText="Ej. 20230001" style="-fx-pref-height: 35;"/>
                <Label fx:id="errorMatricula" styleClass="text-danger" visible="false" managed="false"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Nombre Completo *" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoNombre" promptText="Ej. Juan Pérez García" style="-fx-pref-height: 35;"/>
                <Label fx:id="errorNombre" styleClass="text-danger" visible="false" managed="false"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Correo Electrónico" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoEmail" promptText="ejemplo@escuela.edu" style="-fx-pref-height: 35;"/>
                <Label fx:id="errorEmail" styleClass="text-danger" visible="false" managed="false"/>
            </VBox>

            <Label fx:id="labelNotaPassword" text="Nota: Los alumnos nuevos se crean con la contraseña predeterminada '123456'." style="-fx-text-fill: #6c757d; -fx-font-size: 11px;" wrapText="true"/>
            
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="btnRestablecerPassword" text="Restablecer Contraseña" onAction="#handleRestablecerPassword" styleClass="danger, flat" style="-fx-pref-height: 35;" visible="false" managed="false"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Cancelar" onAction="#handleCancelar" styleClass="flat" style="-fx-pref-height: 35;"/>
                <Button fx:id="botonGuardar" text="Guardar" onAction="#handleGuardar" styleClass="accent" style="-fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true" 
           StackPane.alignment="BOTTOM_CENTER" 
           style="-fx-translate-y: -40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);"/>

    <StackPane fx:id="panelConfirmacion" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 30;">
            
            <Label fx:id="lblTituloConfirmacion" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true" style="-fx-text-fill: #495057; -fx-font-size: 14px;"/>
            
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion" styleClass="flat" style="-fx-pref-height: 35;"/>
                <Button fx:id="btnConfirmarAccion" text="Confirmar" onAction="#handleEjecutarConfirmacion" style="-fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>