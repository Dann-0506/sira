<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.academico.core.ui.DashboardController"
            stylesheets="@../css/base.css,
                         @../css/components.css,
                         @../css/dashboard.css">

    <!-- ── Barra lateral ── -->
    <left>
        <VBox styleClass="sidebar" spacing="0">

            <!-- Perfil del usuario -->
            <VBox spacing="4" style="-fx-padding: 8 0 16 0;">
                <Label fx:id="labelNombreUsuario"
                    text="Cargando..."
                    style="-fx-font-size: 15px; -fx-font-weight: bold;
                            -fx-wrap-text: true;"/>
                <Label fx:id="labelRolUsuario"
                    text=""
                    styleClass="subtitulo-seccion"
                    style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;"/>
            </VBox>

            <Separator style="-fx-padding: 0 0 12 0;"/>
            <Region style="-fx-pref-height: 12px;"/>

            <!-- Navegación dinámica según rol -->
            <VBox fx:id="menuNavegacion" spacing="2" VBox.vgrow="ALWAYS"/>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-padding: 0 0 12 0;"/>
            <Region style="-fx-pref-height: 8px;"/>

            <!-- Cerrar sesión -->
            <Button text="Cerrar sesión"
                    maxWidth="Infinity"
                    styleClass="sidebar-boton"
                    style="-fx-text-fill: -color-danger-fg;"
                    onAction="#handleCerrarSesion"/>

        </VBox>
    </left>

    <!-- ── Área de contenido principal ── -->
    <center>
        <StackPane fx:id="areaPrincipal"
                   styleClass="contenido-principal">
            <!-- Bienvenida inicial -->
            <VBox alignment="CENTER" spacing="8">
                <Label fx:id="labelBienvenida"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="Selecciona una opción del menú para comenzar."
                       styleClass="subtitulo-seccion"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>